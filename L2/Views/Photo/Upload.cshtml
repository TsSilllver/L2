@{
    ViewData["Title"] = "Загрузка фотографии";
}

<h2>Загрузить новое фото</h2>

<form asp-action="Upload" method="post" enctype="multipart/form-data">
    <div class="form-group mb-3">
        <label class="form-label">Название (необязательно)</label>
        <input type="text" name="name" class="form-control" placeholder="Оставьте пустым — будет имя файла" />
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Выберите изображение *</label>
        <input type="file" name="uploadedFile" class="form-control" accept="image/jpeg,image/png,image/gif,image/bmp" required />
    </div>

    <button type="submit" class="btn btn-success">Загрузить</button>
    <a asp-action="Index" class="btn btn-secondary">Отмена</a>
</form>