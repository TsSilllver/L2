@model L2.Models.AnimeCharacter

<h1>Удаление персонажа</h1>
<h3>Вы уверены, что хотите удалить этого персонажа?</h3>

<form method="post">
    <div class="form-group">
        <label>Имя:</label>
        <input value="@Model.Name" type="text" class="form-control" disabled>
    </div>

    <div class="form-group">
        <label>Описание:</label>
        <input value="@Model.Description" type="text" class="form-control" disabled>
    </div>

    <div class="form-group">
        <label>Возраст:</label>
        <input value="@Model.Age" type="text" class="form-control" disabled>
    </div>

    <div class="form-group">
        <label>Картинка:</label>
        <img src="@Model.ImageUrl" alt="@Model.Name" style="width: 200px; object-fit: cover;">
    </div>

    <div class="form-group">
        <label>Студия:</label>
        <input value="@Model.Studio?.Name" type="text" class="form-control" disabled>
    </div>

    <input type="hidden" asp-for="Id" />
    <input type="submit" class="btn btn-danger" value="Удалить" />
    <a asp-action="Index" class="btn btn-secondary">Отмена</a>
</form>