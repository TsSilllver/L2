@model L2.Models.AnimeCharacter

<div class="d-flex justify-content-center">
    <div class="card" style="width: 24rem;">
        <img class="card-img-top" src="@Model.ImageUrl" alt="@Model.Name">
        <div class="card-body">
            <h4>@Model.Name</h4>
            <p><strong>Возраст:</strong> @Model.Age лет</p>
            <p><strong>Описание:</strong> @Model.Description</p>
            @if (Model.Studio != null)
            {
                <p><strong>Студия:</strong> @Model.Studio.Name (@Model.Studio.Country, основана в @Model.Studio.FoundedYear)</p>
            }
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Назад</a>
        </div>
    </div>
</div>