@model L2.ViewModels.EditCharacterViewModel

<h1>Редактировать</h1>

<form method="post">
    <input type="hidden" asp-for="Character.Id" />

    <div class="form-group">
        <label>Имя персонажа:</label>
        <input asp-for="Character.Name" class="form-control" />
    </div>

    <div class="form-group">
        <label>Описание:</label>
        <input asp-for="Character.Description" class="form-control" />
    </div>

    <div class="form-group">
        <label>Возраст:</label>
        <input asp-for="Character.Age" type="number" class="form-control" />
    </div>

    <div class="form-group">
        <label>URL картинки:</label>
        <input asp-for="Character.ImageUrl" class="form-control" />
    </div>

    <div class="form-group">
        <label>Студия:</label>
        <select asp-for="Character.StudioId" class="form-control" asp-items="@(new SelectList(Model.Studios, "Id", "Name"))"></select>
    </div>

    <button type="submit" class="btn btn-primary">Сохранить</button>
    <a asp-action="Index" class="btn btn-secondary">Отмена</a>
</form>