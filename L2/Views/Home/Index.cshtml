@using L2.Models
@using L2.ViewModels
@model IndexCharacterViewModel

<div class="container mt-4">
    <form method="get" class="mb-4">
        <div class="row g-2">
            <div class="col-md-10">
                <input type="text" value="@Model.FilteredCharactersViewModel.NameCharacter" 
                       name="nameCharacter" class="form-control" placeholder="Введите имя персонажа">
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Найти</button>
            </div>
        </div>
    </form>

    <div class="row g-4">
        @foreach (var character in Model.PaginatedViewModelList.Items)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden">
                    <img class="card-img-top" src="@character.ImageUrl" alt="@character.Name" style="height: 200px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold">@character.Name</h5>
                        <p class="card-text text-muted">Возраст: @character.Age лет</p>
                        <p class="card-text flex-grow-1">@character.Description</p>
                        <a asp-controller="Home" asp-action="Details" asp-route-id="@character.Id" class="btn btn-outline-primary mt-2 rounded-pill">Подробнее</a>
                        <a asp-controller="Home" asp-action="Edit" asp-route-id="@character.Id" class="btn btn-outline-warning mt-2 rounded-pill">Редактировать</a>
                        <a asp-controller="Home" asp-action="Delete" asp-route-id="@character.Id" class="btn btn-outline-danger mt-2 rounded-pill">Удалить</a>
                    </div>
                </div>
            </div>
        }
    </div>

    <nav class="mt-4">
        <ul class="pagination">
            <li class="page-item @(Model.PaginatedViewModelList.HasPreviousPage ? string.Empty : "disabled")">
                <a class="page-link" 
                   asp-route-nameCharacter="@Model.FilteredCharactersViewModel.NameCharacter" 
                   asp-route-pageIndex="@(Model.PaginatedViewModelList.PageIndex - 1)">
                    Предыдущая
                </a>
            </li>

            @for (int pageCount = 1; pageCount <= Model.PaginatedViewModelList.TotalPages; pageCount++)
            {
                <li class="page-item @(pageCount == Model.PaginatedViewModelList.PageIndex ? "active" : string.Empty)">
                    <a class="page-link" 
                       asp-route-nameCharacter="@Model.FilteredCharactersViewModel.NameCharacter" 
                       asp-route-pageIndex="@pageCount">
                        @pageCount
                    </a>
                </li>
            }

            <li class="page-item @(Model.PaginatedViewModelList.HasNextPage ? string.Empty : "disabled")">
                <a class="page-link" 
                   asp-route-nameCharacter="@Model.FilteredCharactersViewModel.NameCharacter" 
                   asp-route-pageIndex="@(Model.PaginatedViewModelList.PageIndex + 1)">
                    Следующая
                </a>
            </li>
        </ul>
    </nav>
</div>